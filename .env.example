# ===== Telegram =====
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
ADMIN_IDS=123456789

# ===== Database =====
# Локально — SQLite (создаётся автоматически):
DATABASE_URL=sqlite+aiosqlite:///./freelance_radar.db
# Railway PostgreSQL (подставится сама):
# DATABASE_URL=postgresql+asyncpg://...

# ===== GigaChat =====
# Client ID и Authorization Key из console.cloud.sberbank.ru
GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_AUTH_KEY=your_authorization_key_base64
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ===== YooKassa (опционально) =====
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ===== Proxy (опционально) =====
PROXIES=

# ===== Парсинг =====
PARSE_INTERVAL_SECONDS=120
LOG_LEVEL=INFO
